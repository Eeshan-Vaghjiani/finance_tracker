rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /transactions/{transactionId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    match /groups/{groupId} {
      allow read, update: if request.auth != null && request.auth.token.email in resource.data.members;
      allow create: if request.auth != null && request.auth.token.email in request.resource.data.members;

      match /expenses/{expenseId} {
        allow read: if request.auth != null && request.auth.token.email in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        allow create, update: if request.auth != null && request.auth.token.email in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
    }
  }
}
